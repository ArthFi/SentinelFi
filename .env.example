# .env.example — copy to .env and fill in values
# This file is NOT committed to git. See .gitignore.

# === Contract Deployment (Foundry) ===
PRIVATE_KEY=                        # deployer wallet private key
SEPOLIA_RPC_URL=                    # Alchemy or Infura Sepolia endpoint
ETHERSCAN_API_KEY=                  # for contract verification
ADMIN_ADDRESS=                      # admin role address for LoanFacility

# Forwarder contract address for your environment
# Sepolia mock simulation:  0x15fC6ae953E024d975e77382eEeC56A9101f9F88
# Sepolia production:       0xF8344CFd5c43616a4366C34E3EEE75af79a74482
KEYSTONE_FORWARDER=0x15fC6ae953E024d975e77382eEeC56A9101f9F88

# === CRE Workflow Simulation ===
GEMINI_API_KEY=                     # get from https://aistudio.google.com/apikey
CRE_ETH_PRIVATE_KEY=                # 64-char hex, no 0x prefix, funded with Sepolia ETH
CRE_API_KEY=                        # CRE platform API key (from cre.chain.link)

# === Post-Deployment (fill after deploy) ===
CONTRACT_ADDRESS=
MOCK_API_URL=
